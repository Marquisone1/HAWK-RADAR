# HAWK RADAR — Environment variables
# Copy to .env and adjust as needed.

# Flask secret key — leave empty to auto-generate (stored in /data/secret_key)
SECRET_KEY=

# Environment: development | production
FLASK_ENV=production

# Internal port (inside container)
FLASK_PORT=3001

# Secure session cookies (set to "true" behind HTTPS)
SESSION_COOKIE_SECURE=false

# RSS feed auto-refresh interval in seconds (default: 900 = 15 min)
FEED_REFRESH_INTERVAL=900
